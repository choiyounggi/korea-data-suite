# Copy to deploy/site.env (gitignored) and fill in. Sourced by scripts/publish_site.sh.
KDS_SITE_URL=https://data.yourdomain.com      # canonical base for the SEO site
KDS_API_ORIGIN=https://api.yourdomain.com     # shown in the curl examples on each page
KDS_CTA_URL=https://rapidapi.com/your/api     # signup CTA target (RapidAPI/Zyla/Postman)
KDS_PAGES_PROJECT=kds-site                     # Cloudflare Pages project name

# Cloudflare auth: either run `wrangler login` once (interactive), or set a token:
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
