# Copy to deploy/site.env (gitignored) and fill in. Sourced by scripts/publish_site.sh.
# The running API app serves the generated site at non-API paths, so no deploy step.
# The site is served on the same host as the API (api.korea-data.cloud), so
# KDS_SITE_URL == KDS_API_ORIGIN — canonical/sitemap must match where it's served.
KDS_SITE_URL=https://api.korea-data.cloud      # canonical base (where the site is actually served)
KDS_API_ORIGIN=https://api.korea-data.cloud    # shown in the on-page curl examples
KDS_CTA_URL=https://rapidapi.com/your/api      # signup CTA target (RapidAPI/Zyla/Postman)
# KDS_SITE_DIR=site/dist                        # must match the app's KDS_SITE_DIR (default site/dist)
# KDS_GSC_VERIFICATION=                          # Google Search Console HTML-tag token (content value); injects the verify meta
