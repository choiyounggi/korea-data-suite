<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.choiyounggi.kds-site</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/choeyeonggi/korea-data-suite/scripts/publish_site.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/choeyeonggi/korea-data-suite</string>
