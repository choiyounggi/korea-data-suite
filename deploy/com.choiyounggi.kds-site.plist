        <integer>4</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/choeyeonggi/Library/Logs/kds/site.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/choeyeonggi/Library/Logs/kds/site.err.log</string>
